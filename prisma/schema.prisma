generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Inspection {
  id               String   @id @default(uuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  propertyType     String   // residential | commercial
  status           String   @default("new")
  // new → pending_approval → estimate_sent → accepted | declined

  // Inspector MacTor — Inspection context
  serviceType        String   @default("repair")  // repair | renovation | new_project
  problemDescription String?   // client's free-text description
  issueCategory      String?   // plumbing | electrical | structural | hvac | roofing | water_damage | pests | doors_windows | exterior | other
  followUpAnswers    Json?     // [{ question, answer }]

  // Client info
  clientName       String?
  clientEmail      String?
  clientPhone      String?
  clientLanguage   String   @default("en")  // en | es | zh | hi | tl
  address          String?
  exifCoords       Json?

  // Photos (Cloudinary URLs)
  photos           Json     @default("[]")

  // AI Analysis
  aiAnalysis       Json?    // Claude Vision full analysis per photo
  aiSummary        Json?    // Aggregated summary

  // Pricing
  aiEstimate       Json?    // AI-generated estimate
  approvedEstimate Json?    // Julio's approved estimate
  approvalNotes    String?  // Julio's notes for AI training

  // Tokens
  approvalToken    String   @unique @default(uuid())
  acceptToken      String   @unique @default(uuid())

  // Timestamps
  approvedAt       DateTime?
  estimateSentAt   DateTime?
  acceptedAt       DateTime?

  trainingData     TrainingData[]
}

model Invoice {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  invoiceNumber String    @unique  // INV0200, INV0201 ...
  type          String    @default("invoice")   // invoice | estimate
  status        String    @default("draft")     // draft | sent | paid | overdue

  // Client
  clientName    String
  clientEmail   String?
  clientPhone   String?
  clientAddress String?

  // Line items: [{description, rate, qty, amount, notes}]
  lineItems     Json      @default("[]")

  // Totals
  subtotal      Float     @default(0)
  hst           Float     @default(0)
  total         Float     @default(0)

  // Content
  notes         String?
  photos        Json      @default("[]")  // Cloudinary URLs

  // Dates
  invoiceDate   DateTime  @default(now())
  dueDate       String    @default("On Receipt")
  sentAt        DateTime?
  paidAt        DateTime?

  // Link to inspector (optional)
  inspectionId  String?
}

model InvoiceCounter {
  id      Int @id @default(autoincrement())
  lastNum Int @default(199)
}

model ServiceCatalog {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  name         String   @unique   // "Masonry Cleaning & Sealing"
  category     String?            // "Masonry" | "Drainage" | "Landscaping" | ...
  description  String?            // most recent scope description
  unit         String?            // "lump sum" | "lf" | "sqft" | ...

  lastPrice    Float
  minPrice     Float
  maxPrice     Float
  avgPrice     Float
  useCount     Int      @default(1)

  priceHistory Json     @default("[]") // [{date,price,estimateNumber,clientName}]
}

model TrainingData {
  id               String   @id @default(uuid())
  createdAt        DateTime @default(now())

  inspectionId     String
  inspection       Inspection @relation(fields: [inspectionId], references: [id])

  propertyType     String
  damageType       String
  aiPriceSuggested Float
  julioApprovedPrice Float
  julioNote        String?
}
